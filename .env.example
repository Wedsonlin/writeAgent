# Optional direct OpenAI credentials for LangChain defaults.
# writeAgent's configured runtime uses WRITEAGENT_LLM_* below.
OPENAI_API_KEY=

# Optional LangSmith/LangGraph development credentials
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true

# Required on Windows terminals that default to GBK when running langgraph dev
PYTHONUTF8=1

# ----------------------------------------------------------------------------
# writeAgent Deep Agents runtime configuration (copy to `.env` and fill in values)
# ----------------------------------------------------------------------------
# The Deep Agents harness reads LLM credentials from these env vars.
# OpenAI-compatible protocol is used so you can swap providers freely.
# The `openai:` model prefix selects the OpenAI-compatible LangChain adapter;
# it does not mean the request must go to OpenAI.
#
# Examples:
#   * DeepSeek (recommended):      https://api.deepseek.com                           model=deepseek-v4-flash
#   * DeepSeek higher quality:     https://api.deepseek.com                           model=deepseek-v4-pro
#   * DashScope Qwen:              https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-plus
#   * GLM-4:                       https://open.bigmodel.cn/api/paas/v4               model=glm-4-flash
#   * OpenAI:                      https://api.openai.com/v1                          model=gpt-4o-mini
# ----------------------------------------------------------------------------

WRITEAGENT_LLM_API_KEY=sk-your-deepseek-key
WRITEAGENT_LLM_BASE_URL=https://api.deepseek.com
WRITEAGENT_MODEL=openai:deepseek-v4-flash

# Optional Tavily search credentials and async connection-pool tuning.
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
WRITEAGENT_SEARCH_TIMEOUT_SEC=30
WRITEAGENT_SEARCH_MAX_CONNECTIONS=20
WRITEAGENT_SEARCH_MAX_KEEPALIVE=10
WRITEAGENT_SEARCH_CACHE_TTL_DAYS=30

# Optional: workspace root used for projects, artifacts, progress, and traces.
# Defaults to `<repo>/.writeagent` when unset.
# WRITEAGENT_WORKSPACE=
