{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://writeagent.local/schemas/paper_outline.schema.json",
  "title": "PaperOutline",
  "description": "Skill 3（论文大纲与章节框架设计）的输出。本仓库给出接口契约。",
  "type": "object",
  "required": ["sections", "total_word_budget"],
  "properties": {
    "total_word_budget": { "type": "integer" },
    "sections": {
      "type": "array",
      "description": "完整的章节结构（含一级 / 二级 / 三级）",
      "items": {
        "type": "object",
        "required": ["id", "title", "level", "key_points"],
        "properties": {
          "id": { "type": "string", "description": "如 1 / 1.1 / 1.1.2" },
          "title": { "type": "string" },
          "level": { "type": "integer", "minimum": 1, "maximum": 4 },
          "parent_id": { "type": ["string", "null"] },
          "key_points": { "type": "array", "items": { "type": "string" } },
          "transition_note": { "type": "string", "description": "本节与前后章节的逻辑衔接说明" },
          "word_budget": { "type": "integer" },
          "supporting_papers": {
            "type": "array",
            "description": "本节引用的文献 id（指向 literature_report.papers.id）",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
