{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://writeagent.local/schemas/paper_draft.schema.json",
  "title": "PaperDraft",
  "description": "Skill 4（分章节内容生成）的输出。本仓库给出接口契约。",
  "type": "object",
  "required": ["sections", "abstract"],
  "properties": {
    "abstract": { "type": "string" },
    "keywords": { "type": "array", "items": { "type": "string" } },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "content_markdown"],
        "properties": {
          "id": { "type": "string", "description": "对应 paper_outline.sections.id" },
          "title": { "type": "string" },
          "content_markdown": { "type": "string", "description": "本节正文（Markdown），自动嵌入引用标记如 [1]、[2]" },
          "citations_used": { "type": "array", "items": { "type": "string" }, "description": "本节用到的文献 id" },
          "word_count": { "type": "integer" }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "description": "Skill 4 在生成时遇到的疑问或留白（供 Skill 5/6 关注）",
      "items": { "type": "string" }
    }
  }
}
