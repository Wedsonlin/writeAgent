{
  "dependencies": ["."],
  "graphs": {
    "writeagent": "server/graph.py:graph"
  },
  "env": ".env",
  "http": {
    "app": "server/webapp.py:app",
    "cors": {
      "allow_origins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "http://localhost:5174",
        "http://127.0.0.1:5174"
      ],
      "allow_methods": ["GET", "POST", "OPTIONS"],
      "allow_headers": ["*"],
      "allow_credentials": true
    }
  }
}
