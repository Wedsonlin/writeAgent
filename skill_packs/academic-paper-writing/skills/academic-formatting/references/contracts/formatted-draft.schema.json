{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormattedDraft",
  "type": "object",
  "required": [
    "normalized_draft",
    "markdown",
    "markdown_path",
    "docx_path",
    "export_status",
    "template_profile",
    "template_conformance_report",
    "format_check_report",
    "issues",
    "quality_checks"
  ],
  "properties": {
    "normalized_draft": {
      "type": "object",
      "required": ["title", "abstract", "keywords", "sections", "references"],
      "properties": {
        "title": {"type": "string"},
        "abstract": {"type": "string"},
        "keywords": {"type": "array", "items": {"type": "string"}},
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["title", "content_markdown"],
            "properties": {
              "id": {"type": "string"},
              "title": {"type": "string"},
              "level": {"type": "integer", "minimum": 1},
              "content_markdown": {"type": "string"},
              "citations_used": {"type": "array", "items": {"type": "string"}},
              "word_count": {"type": "integer"}
            },
            "additionalProperties": true
          }
        },
        "references": {"type": "array"},
        "open_questions": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "markdown": {
      "type": "string",
      "minLength": 1,
      "description": "Full rendered paper Markdown"
    },
    "markdown_path": {
      "type": "string",
      "description": "Filesystem path to the Markdown sidecar written beside the JSON output"
    },
    "docx_path": {
      "type": "string",
      "description": "Filesystem path to the required formatted DOCX export"
    },
    "pdf_path": {
      "type": ["string", "null"],
      "description": "Filesystem path to PDF export when generated; null when unavailable"
    },
    "template_profile": {
      "type": ["string", "null"],
      "description": "Document template profile used by the exporter, e.g. journal_of_software_2025"
    },
    "template_source_path": {
      "type": ["string", "null"],
      "description": "Template sample path that selected the profile, when available"
    },
    "template_conformance_report": {
      "type": "object",
      "required": ["profile", "checks", "passed"],
      "description": "Machine-readable checks for DOCX template conformance",
      "additionalProperties": true
    },
    "export_status": {
      "type": "object",
      "required": ["docx", "pdf"],
      "properties": {
        "docx": {
          "type": "object",
          "required": ["status", "path"],
          "properties": {
            "status": {"type": "string", "enum": ["generated"]},
            "path": {"type": "string"}
          },
          "additionalProperties": true
        },
        "pdf": {
          "type": "object",
          "required": ["status"],
          "properties": {
            "status": {"type": "string", "enum": ["generated", "unavailable"]},
            "path": {"type": ["string", "null"]},
            "reason": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "format_check_report": {
      "type": "object",
      "required": ["target_template", "total_issues", "fixed_issues", "warnings", "errors", "export_status"],
      "additionalProperties": true
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "severity", "message"],
        "properties": {
          "code": {
            "type": "string",
            "description": "Machine-readable issue code, e.g. heading_level_jump"
          },
          "severity": {
            "type": "string",
            "enum": ["fixed", "warning", "error"],
            "description": "fixed = auto-corrected; warning = recorded but non-blocking; error = blocking"
          },
          "field": {
            "type": "string",
            "description": "JSON pointer-like path to the affected field"
          },
          "message": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "quality_checks": {
      "type": "object",
      "required": ["headings_normalized", "references_formatted", "docx_exported"],
      "properties": {
        "headings_normalized": {
          "type": "boolean",
          "description": "True when heading hierarchy has no unresolved warnings"
        },
        "references_formatted": {
          "type": "boolean",
          "description": "True when in-text citations and bibliography meet style rules"
        },
        "figures_tables_labeled": {
          "type": "boolean",
          "description": "True when detected figures and tables have numbered captions"
        },
        "docx_exported": {
          "type": "boolean",
          "description": "True when required DOCX export was generated"
        },
        "pdf_exported": {
          "type": "boolean",
          "description": "True when optional PDF export was generated"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
