{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LiteratureReport",
  "type": "object",
  "required": [
    "keywords",
    "papers",
    "research_landscape",
    "consensus",
    "controversies",
    "research_gaps",
    "citation_style",
    "formatted_bibliography"
  ],
  "properties": {
    "keywords": {"type": "array", "items": {"type": "string"}},
    "papers": {"type": "array", "items": {"type": "object"}},
    "research_landscape": {
      "type": "object",
      "required": ["clusters", "timeline_summary"],
      "properties": {
        "clusters": {"type": "array", "items": {"type": "object"}},
        "timeline_summary": {"type": "string"}
      }
    },
    "consensus": {"type": "array", "items": {"type": "string"}},
    "controversies": {"type": "array", "items": {"type": "string"}},
    "research_gaps": {"type": "array", "items": {"type": "string"}},
    "citation_style": {"type": "string"},
    "formatted_bibliography": {
      "type": "object",
      "required": ["gb7714", "apa"],
      "properties": {
        "gb7714": {"type": "array", "items": {"type": "string"}},
        "apa": {"type": "array", "items": {"type": "string"}}
      }
    },
    "unmapped_papers": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
