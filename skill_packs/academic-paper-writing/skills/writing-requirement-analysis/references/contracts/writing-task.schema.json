{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WritingTask",
  "type": "object",
  "required": [
    "topic",
    "paper_type",
    "language",
    "target_journal",
    "word_limit",
    "core_arguments",
    "innovation_points",
    "research_scope",
    "chapter_framework",
    "references_seed",
    "task_book_sections",
    "missing_info"
  ],
  "properties": {
    "topic": {"type": "string"},
    "paper_type": {"type": "string", "enum": ["survey", "research"]},
    "language": {"type": "string"},
    "target_journal": {
      "type": "object",
      "required": ["name", "level", "style_profile"],
      "properties": {
        "name": {"type": "string"},
        "level": {"type": "string"},
        "style_profile": {"type": "object"}
      }
    },
    "word_limit": {
      "type": "object",
      "required": ["total", "by_chapter", "chapter_allocation_stage"],
      "properties": {
        "total": {"type": "integer"},
        "by_chapter": {},
        "chapter_allocation_stage": {"type": "string"}
      }
    },
    "core_arguments": {"type": "array", "items": {"type": "string"}},
    "innovation_points": {"type": "array", "items": {"type": "string"}},
    "research_scope": {"type": "object"},
    "chapter_framework": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "word_budget": {"oneOf": [{"type": "integer"}, {"type": "null"}]}
        },
        "additionalProperties": true
      }
    },
    "references_seed": {"type": "array", "items": {"type": "object"}},
    "task_book_sections": {
      "type": "object",
      "required": [
        "confirmation_sources_and_assumptions",
        "downstream_constraints",
        "argument_evidence_matrix",
        "target_venue_format_points"
      ],
      "properties": {
        "confirmation_sources_and_assumptions": {
          "type": "object",
          "required": ["confirmed_sources", "assumptions"],
          "properties": {
            "confirmed_sources": {"type": "array", "items": {"type": "object"}},
            "assumptions": {"type": "array", "items": {"type": "string"}}
          }
        },
        "downstream_constraints": {"type": "array", "items": {"type": "object"}},
        "argument_evidence_matrix": {"type": "array", "items": {"type": "object"}},
        "target_venue_format_points": {"type": "object"}
      },
      "additionalProperties": true
    },
    "missing_info": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
