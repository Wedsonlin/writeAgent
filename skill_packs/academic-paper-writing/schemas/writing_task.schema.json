{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WritingTask",
  "type": "object",
  "required": [
    "topic",
    "paper_type",
    "language",
    "target_journal",
    "word_limit",
    "core_arguments",
    "innovation_points",
    "research_scope",
    "chapter_framework",
    "references_seed",
    "task_book_sections",
    "missing_info"
  ],
  "properties": {
    "topic": {"type": "string", "minLength": 1},
    "paper_type": {"type": "string", "enum": ["survey", "research"]},
    "language": {"type": "string"},
    "target_journal": {
      "type": "object",
      "required": ["name", "level", "style_profile"],
      "properties": {
        "name": {"type": "string"},
        "level": {"type": "string"},
        "style_profile": {
          "type": "object",
          "required": ["citation_style", "tone", "structure_hint"],
          "properties": {
            "citation_style": {"type": "string"},
            "tone": {"type": "string"},
            "structure_hint": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "word_limit": {
      "type": "object",
      "required": ["total", "by_chapter", "chapter_allocation_stage"],
      "properties": {
        "total": {"type": "integer", "minimum": 1},
        "by_chapter": {},
        "chapter_allocation_stage": {"type": "string", "const": "paper_outline"}
      },
      "additionalProperties": true
    },
    "core_arguments": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "innovation_points": {"type": "array", "items": {"type": "string"}},
    "research_scope": {
      "type": "object",
      "required": ["domain", "subtopics", "boundary"],
      "properties": {
        "domain": {"type": "string"},
        "subtopics": {"type": "array", "items": {"type": "string"}},
        "boundary": {"type": "string"}
      },
      "additionalProperties": true
    },
    "chapter_framework": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter_id", "title", "key_points", "word_budget", "depends_on"],
        "properties": {
          "chapter_id": {"type": "string"},
          "title": {"type": "string"},
          "key_points": {"type": "array", "items": {"type": "string"}},
          "word_budget": {"oneOf": [{"type": "integer", "minimum": 0}, {"type": "null"}]},
          "depends_on": {}
        },
        "additionalProperties": true
      }
    },
    "references_seed": {"type": "array", "items": {"type": "object"}},
    "task_book_sections": {
      "type": "object",
      "required": [
        "confirmation_sources_and_assumptions",
        "downstream_constraints",
        "argument_evidence_matrix",
        "target_venue_format_points"
      ],
      "properties": {
        "confirmation_sources_and_assumptions": {
          "type": "object",
          "required": ["confirmed_sources", "assumptions"],
          "properties": {
            "confirmed_sources": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["field", "source"],
                "properties": {
                  "field": {"type": "string"},
                  "source": {"type": "string"}
                },
                "additionalProperties": true
              }
            },
            "assumptions": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        },
        "downstream_constraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["stage", "constraint"],
            "properties": {
              "stage": {"type": "string"},
              "constraint": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "argument_evidence_matrix": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["argument", "evidence_needs"],
            "properties": {
              "argument": {"type": "string"},
              "evidence_needs": {"type": "array", "items": {"type": "string"}}
            },
            "additionalProperties": true
          }
        },
        "target_venue_format_points": {
          "type": "object",
          "required": ["target_name", "level", "citation_style", "tone", "structure_hint"],
          "properties": {
            "target_name": {"type": "string"},
            "level": {"type": "string"},
            "citation_style": {"type": "string"},
            "tone": {"type": "string"},
            "structure_hint": {"type": "string"}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "missing_info": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field", "question", "criticality", "suggested_default"],
        "properties": {
          "field": {"type": "string"},
          "question": {"type": "string"},
          "criticality": {"type": "string"},
          "suggested_default": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
